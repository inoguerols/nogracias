# Copia este archivo a .env y rellénalo. .env está en .gitignore (NO se sube).
# Solo lo necesita filter.py (el modo IMAP universal).
# Los filtros nativos (dist/nogracias.sieve, dist/gmail-filters.xml) NO usan esto.

IMAP_HOST=mail.tudominio.com
IMAP_PORT=993
IMAP_SSL=1
IMAP_USER=tucorreo@tudominio.com
# Usa una "contraseña de aplicación" si tu proveedor la ofrece (Gmail, etc.).
IMAP_PASS=tu_contraseña

# Carpeta destino (se crea sola si no existe).
# Dovecot/Plesk suele querer el prefijo INBOX. con punto: INBOX.IA-no-solicitado
IMAP_FOLDER=INBOX.IA-no-solicitado

# --- Capa IA OPCIONAL (llm.py). Déjalo vacío para usar solo reglas (gratis). ---
# Trae tu modelo: cualquier proveedor compatible con OpenAI, o uno LOCAL y gratis.
#
#  Nube (Anthropic, baratísimo con Haiku):
#    LLM_API_KEY=sk-ant-...          # tu clave Anthropic
#    (LLM_API_BASE y LLM_MODEL ya traen buenos valores por defecto)
#
#  Local y gratis (Ollama en tu máquina/servidor — el correo NO sale de ahí):
#    LLM_API_KEY=ollama              # cualquier valor no vacío
#    LLM_API_BASE=http://localhost:11434/v1
#    LLM_MODEL=llama3.1
#
LLM_API_KEY=
# LLM_API_BASE=https://api.anthropic.com/v1
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_SEND_BODY=1     # 0 = enviar solo el asunto (más privado)
